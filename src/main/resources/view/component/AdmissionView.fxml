<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="870.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ams.ams_app.controller.AdmissionController">
    <children>
        <!-- VBox chính bao phủ toàn bộ diện tích Center -->
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Thanh công cụ điều hướng và thông tin ngành -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="35.0" prefWidth="80.0" styleClass="back-btn" stylesheets="@../../css/style.css" text="Trở lại" />
                        <Label text="Ngành:">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label fx:id="txtMajorName" maxWidth="1.7976931348623157E308" styleClass="subtitle-label" text="Tên ngành đào tạo" HBox.hgrow="ALWAYS">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <HBox spacing="15.0" alignment="CENTER_RIGHT">
                            <children>
                                <Label text="Chỉ tiêu:">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Label fx:id="txtQuota" styleClass="subtitle-label" text="0" />
                                <Label text="Điểm chuẩn:">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Label fx:id="txtFinalScore" styleClass="subtitle-label" text="0.0" />
                                <Button fx:id="btnMajorStatus" onAction="#changeMajorStatus" prefHeight="35.0" prefWidth="150.0" styleClass="btn-2" text="Trạng thái" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Phần bảng danh sách thí sinh -->
                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="Danh sách nguyện vọng xét tuyển">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TableView fx:id="tableView" stylesheets="@../../css/style.css" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" maxWidth="80.0" minWidth="50.0" prefWidth="60.0" text="ID" />
                                        <TableColumn fx:id="colSID" minWidth="100.0" prefWidth="120.0" text="SID" />
                                        <TableColumn fx:id="colFullName" minWidth="150.0" prefWidth="200.0" text="Họ Tên" />
                                        <TableColumn fx:id="colCombination" maxWidth="100.0" minWidth="80.0" prefWidth="90.0" text="Tổ hợp" />
                                        <TableColumn fx:id="colPriorityOrder" maxWidth="60.0" minWidth="40.0" prefWidth="50.0" text="NV" />
                                        <TableColumn fx:id="colAcademicYear" maxWidth="70.0" minWidth="50.0" prefWidth="60.0" text="Năm" />
                                        <TableColumn fx:id="colTotalScore" maxWidth="100.0" minWidth="70.0" prefWidth="80.0" text="Điểm" />
                                        <TableColumn fx:id="colMatriculateStatus" minWidth="120.0" prefWidth="150.0" text="Trạng thái" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                    <styleClass>
                                        <String fx:value="table-view" />
                                        <String fx:value="table-row-cell" />
                                        <String fx:value="table-cell" />
                                    </styleClass>
                                </TableView>
                                <Pagination fx:id="pagination" prefHeight="45.0" />
                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleRun" prefHeight="35.0" prefWidth="120.0" styleClass="search-button" stylesheets="@../../css/style.css" text="Chạy xét tuyển" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Phần Nhật ký và Tiến trình -->
                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="Bảng nhật kí hệ thống">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextArea fx:id="logPane" editable="false" prefHeight="150.0" VBox.vgrow="ALWAYS" />
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <ProgressBar fx:id="progressBar" maxWidth="1.7976931348623157E308" prefHeight="30.0" progress="0.0" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnFinalize" disable="true" mnemonicParsing="false" onAction="#handleDone" prefHeight="35.0" styleClass="done-btn" stylesheets="@../../css/style.css" text="Hoàn thiện dữ liệu" visible="false" />
                                    </children>
                                    <padding>
                                        <Insets top="5.0" />
                                    </padding>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
</AnchorPane>